{
  "version": 2,
  "functions": {
    "api/send-email.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/send-email", "dest": "/api/send-email.js" },
    { "src": "/app.js",         "dest": "/app.js" },
    { "src": "/style.css",      "dest": "/style.css" },
    { "src": "/(.*)",           "dest": "/index.html" }
  ]
}
